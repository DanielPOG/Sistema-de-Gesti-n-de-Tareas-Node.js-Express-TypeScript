# ─────────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─────────────────────────────────────────────
# Seguridad JWT
# ─────────────────────────────────────────────
# Clave secreta para firmar los tokens. Usa un string largo y aleatorio.
JWT_SECRET="your_jwt_secret_here"

# Tiempo de expiración del token (ejemplos: 7d, 24h, 60m)
JWT_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000