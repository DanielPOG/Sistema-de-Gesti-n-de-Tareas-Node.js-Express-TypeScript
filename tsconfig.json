{
    "compilerOptions": {
        /* Compilación */
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        /* Rutas */
        "rootDir": "./src",
        "outDir": "./dist",
        /* Resolución de módulos */
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        /* Calidad y seguridad */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        /* Rendimiento */
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        /* Source maps para depuración */
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}